{
  "name": "react-klinecharts-ui",
  "version": "0.2.0",
  "description": "Headless React components for building financial trading terminals with klinecharts",
  "author": "NemeZZiZZ",
  "repository": {
    "type": "git",
    "url": "https://github.com/NemeZZiZZ/react-klinecharts-ui"
  },
  "homepage": "https://github.com/NemeZZiZZ/react-klinecharts-ui#readme",
  "bugs": {
    "url": "https://github.com/NemeZZiZZ/react-klinecharts-ui/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./extensions": {
      "import": {
        "types": "./dist/extensions.d.ts",
        "default": "./dist/extensions.js"
      },
      "require": {
        "types": "./dist/extensions.d.cts",
        "default": "./dist/extensions.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{ts,tsx}\""
  },
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0",
    "react-klinecharts": ">=0.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^10.0.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "prettier": "^3.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-klinecharts": "0.1.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.56.1"
  },
  "license": "Apache-2.0",
  "packageManager": "pnpm@10.24.0",
  "engines": {
    "node": ">=16.0.0"
  },
  "sideEffects": false,
  "keywords": [
    "react",
    "klinecharts",
    "trading",
    "financial",
    "terminal",
    "headless",
    "chart",
    "candlestick",
    "indicators",
    "drawing-tools"
  ]
}
